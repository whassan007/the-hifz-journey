FROM node:20-alpine

WORKDIR /app

# Enable corepack for pnpm if necessary, or just use npm
COPY package*.json ./
RUN npm ci

# Copy the entire app including the api directory and tsx configuration
COPY . .

# Expose mapping port for Cloud Run
EXPOSE 8080
ENV PORT=8080 
ENV NODE_ENV=production

# Run with TSX to natively execute the TypeScript express wrapper without requiring an explicit tsc build phase
CMD ["npx", "tsx", "server.ts"]
